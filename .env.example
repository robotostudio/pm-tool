# Linear API key (Settings > API > Personal API keys)
LINEAR_API_KEY=lin_api_xxxxx

# Slack incoming webhook URL (used by daily WIP cron)
SLACK_WEBHOOK_URL=

# Slack Bot OAuth token (Bot User OAuth Token from Slack app settings > OAuth & Permissions)
SLACK_BOT_TOKEN=xoxb-xxxxx

# Slack signing secret (from Slack app > Basic Information > Signing Secret)
SLACK_SIGNING_SECRET=

# Optional: comma-separated Linear team keys to track (leave empty for all teams)
TEAM_FILTER=

# Secret to protect cron and report endpoints (set in Vercel env vars, sent as CRON_SECRET)
CRON_SECRET=

# Vercel Postgres connection string (auto-set by Vercel Marketplace Neon integration)
POSTGRES_URL=
