# Linear API key (Settings > API > Personal API keys)
LINEAR_API_KEY=lin_api_xxxxx

# Slack incoming webhook URL
SLACK_WEBHOOK_URL=

# Optional: comma-separated Linear team keys to track (leave empty for all teams)
TEAM_FILTER=

# Secret to verify Linear webhook signatures
LINEAR_WEBHOOK_SECRET=

# Secret to protect cron endpoints (set in Vercel env vars, sent as CRON_SECRET)
CRON_SECRET=

# Vercel Postgres connection string (auto-set by Vercel Marketplace Neon integration)
POSTGRES_URL=
